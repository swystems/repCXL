# RepCXL configuration file
# Example usage: <binary> -c config/example.toml

# Memory nodes. In the VM setup, memory regions of the CXL node from the host 
# are exposed as PCI devices with inter-vm shared memory 
mem_nodes = [
"/dev/dax0.1",
"/dev/dax0.2",
"/dev/dax0.3",
"/dev/dax0.4",
"/dev/dax0.5",
"/dev/dax0.6",
"/dev/dax0.7",
"/dev/dax0.8",
"/dev/dax0.9",
"/dev/dax0.10",
"/dev/dax0.11",
"/dev/dax0.12",
"/dev/dax0.13",
"/dev/dax0.14",
"/dev/dax0.15",
"/dev/dax0.16",
"/dev/dax0.17",
"/dev/dax0.18",
"/dev/dax0.19",
"/dev/dax0.20",
"/dev/dax0.21",
]

# memory node/region used for state & shared memory communication with logger processes
logger_node = "/dev/dax0.0"

# Total size of each memory node in bytes, padded to chunk size
mem_size = 1_000_000_000 

# (required) unique identifier for the repCXL instance. Can be passed with -i
id = {{ repcxl_id }} 

# List of process IDs in the cluster. Can be specified as:
#   - A number (4) → generates IDs [0, 1, 2, 3]
#   - A range string ("0..3" or "0-3") → generates IDs [0, 1, 2, 3]
processes = {{ process_list | to_json }}

# Number of logger processes. If the value is N, N repCXL processes will spawn
# _one_ logger process. The value must be odd (due to quorum-based replication)
# and cannot be larger than the number of processes in the cluster. 
logger_cluster_size = {{ logger_cluster_size }}

# (ns) Time to wait for all processes to start up (in nanoseconds)
startup_delay = 1000000000

# (ns) Duration of the synchronous round (in nanoseconds)
round_time = {{ round_time }} 

# Replication algorithm: "monster", "sync_best_effort", "async_best_effort"
algorithm = "{{ algorithm }}"

# Enable pipelined write path (true/false)
pipeline = {{ (pipeline | default(false)) | string | lower }}

# Number of times to retry a read operation if it returns a dirty read
read_retries = {{ read_retries }}

# List of CPU cores. Can be specified as:
#   - A number (4) → generates [0, 1, 2, 3]
#   - A range string ("0..3" or "0-3") → generates [0, 1, 2, 3]
#   - An array ([0, 10, 22, 31]) → explicit list of cores
# core 0 is not allowed. Core affinity must be larger than the number of processes 
# and the logger cluster size.
core_affinity = {{ core_affinity | to_json }} 

{% if read_offset is defined %}
read_offset = {{ read_offset }}
{% endif %}
